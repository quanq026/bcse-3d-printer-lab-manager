# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=info

# Runtime data location
# Leave commented in local dev to use ./data
# DATA_DIR=/var/data/bcse-3d-lab

# Reverse proxy handling
# In production behind Nginx or another proxy, use 1
TRUST_PROXY=loopback

# CORS - comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# ALLOWED_ORIGINS=https://your-domain.com

# Managed staff accounts
# These are used when the users table is empty on first boot.
SEED_ADMIN_EMAIL=admin@vju.ac.vn
SEED_ADMIN_PASSWORD=Admin@202444
SEED_MOD_EMAIL=mod@vju.ac.vn
SEED_MOD_PASSWORD=Mod@2024

# Optional emergency sync for existing databases.
# Set true for one restart only when you intentionally want env to overwrite
# the password hash of the managed Admin or Moderator accounts.
SYNC_SEED_PASSWORDS=false

# Optional SMTP values (currently stored into settings on first seed only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Production checklist
# 1. Set NODE_ENV=production
# 2. Replace JWT_SECRET with a secure random value
# 3. Set ALLOWED_ORIGINS to your real domain
# 4. Point DATA_DIR to a persistent location outside the repo
# 5. Change managed account passwords before first production boot
# 6. Use SYNC_SEED_PASSWORDS=true for one restart only if rotating managed passwords via env
